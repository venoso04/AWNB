# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/awn_db

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google Sign-In ───────────────────────────────────────
# Get this from Google Cloud Console → APIs & Services → Credentials
# Use the OAuth Client ID configured for your mobile app (Android/iOS)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ─── AI Service ───────────────────────────────────────────
# Base URL for the document analysis service
# Docs:    https://gabr83-graduationproject.hf.space/docs
# Analyze: POST https://gabr83-graduationproject.hf.space/analyze
AI_BASE_URL=https://gabr83-graduationproject.hf.space

# ─── Email / SMTP (used for password reset only) ──────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM_NAME=Awn App

# ─── YouTube Data API ─────────────────────────────────────
YOUTUBE_API_KEY=AIzaSyAVpjwK-PmAb43PjekpUHRo95JNpOvVdLw

# ─── File Upload ──────────────────────────────────────────
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=uploads

# ─── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=*
